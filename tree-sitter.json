{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "oxi",
      "camelcase": "Oxi",
      "title": "Oxi",
      "scope": "source.oxi",
      "file-types": ["oxi"],
      "highlights": ["queries/oxi/highlights.scm"],
      "injection-regex": "^oxi$",
      "class-name": "TreeSitterOxi"
    }
  ],
  "metadata": {
    "version": "1.1.0",
    "license": "MIT",
    "description": "Treesitter parser for the oxi programming language",
    "authors": [
      {
        "name": "septech",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/oxilang/tree-sitter-oxi",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
